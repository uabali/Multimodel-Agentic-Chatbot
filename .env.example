# ── llama-server (binary & model) ─────────────────────────────────────────────
# Absolute path to your compiled llama-server binary (required for `make llm`).
# Build guide: https://github.com/ggml-org/llama.cpp#build
LLAMA_SERVER_BIN=/home/you/llama.cpp/build/bin/llama-server

# Gemma 4 E4B GGUF — downloaded automatically on first run
LLAMA_HF_REPO=lmstudio-community/gemma-4-E4B-it-GGUF:Q4_K_M

# Context window and parallelism — tune to your VRAM:
#  16 GB → CTX=16384 PARALLEL=4   (~9.2 GB)  ✓ Recommended
#  12 GB → CTX=16384 PARALLEL=4   (~9.2 GB)  ✓ Tight but works
#  12 GB → CTX=8192  PARALLEL=4   (~6.6 GB)  ✓ Comfortable
#   8 GB → CTX=8192  PARALLEL=2   (~6.6 GB)  ✓ Comfortable
#   8 GB → CTX=4096  PARALLEL=2   (~5.2 GB)  ✓ Minimal
LLAMA_CTX_SIZE=16384
LLAMA_GPU_LAYERS=auto
LLAMA_PORT=8080
LLAMA_PARALLEL=4

# Multimodal projector — leave blank; llama-server downloads it automatically
# with `-hf` flag. Set an absolute path only if you want to force a local file.
LLAMA_MMPROJ=

# ── LLM Backend (OpenAI-compatible) ───────────────────────────────────────────
LLM_BACKEND=llama.cpp
LLM_SERVER_URL=http://localhost:8080/v1
LLM_MODEL_NAME=gemma-4-e4b

# Vision model served at the same endpoint (multimodal Gemma)
VISION_MODEL=gemma-4-e4b

# Chain-of-thought (vLLM only; ignored by llama.cpp)
LLM_ENABLE_THINKING=false

# HuggingFace token — only needed for gated / private models
HUGGING_FACE_HUB_TOKEN=

# ── LLM profiles ──────────────────────────────────────────────────────────────
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1024
RAG_TEMPERATURE=0.0
RAG_MAX_TOKENS=2048
ROUTER_MAX_TOKENS=64

# ── Agentic RAG profile (tool calling, multi-turn reasoning) ──────────────────
AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=2048

# ── Embedding (HuggingFace) ───────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ── Audio (STT) ──────────────────────────────────────────────────────────────
# STT_MODEL=medium   # tiny | base | small | medium | large

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=user_documents
QDRANT_AUTO_REINDEX=smart

# ── RAG ──────────────────────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K=6
RETRIEVAL_STRATEGY=hybrid
BASE_K=10

# ── Dense Gate ────────────────────────────────────────────────────────────────
RAG_MIN_DENSE_SIMILARITY=0.38

# ── Reranker ─────────────────────────────────────────────────────────────────
USE_RERANK=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DEVICE=cpu

# ── Web Search ───────────────────────────────────────────────────────────────
TAVILY_API_KEY=              # Get free key: https://tavily.com
# BRAVE_API_KEY=             # Alternative: https://brave.com/search/api/

# ── Auth ─────────────────────────────────────────────────────────────────────
APP_ADMIN_USERNAME=admin
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(16))"
APP_ADMIN_PASSWORD=change-me
APP_PASSWORD_SALT=change-me-in-production
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
CHAINLIT_AUTH_SECRET=

# ── MCP Tools (optional) ─────────────────────────────────────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
